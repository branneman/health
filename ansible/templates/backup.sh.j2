#!/usr/bin/env bash
set -euo pipefail
ENV_FILE=/home/deploy/health/.env
get_env() { grep -m1 "^${1}=" "$ENV_FILE" | cut -d= -f2-; }
POSTGRES_USER=$(get_env POSTGRES_USER)
POSTGRES_DB=$(get_env POSTGRES_DB)
STORAGE_BOX_USER=$(get_env STORAGE_BOX_USER)
STORAGE_BOX_HOST=$(get_env STORAGE_BOX_HOST)

BACKUP_FILE="health_$(date +%Y%m%d_%H%M%S).sql.gz"
BACKUP_DIR="/home/deploy/backups"
RETENTION_DAYS=30
SSH_OPTS="-p 23 -i /home/deploy/.ssh/storagebox_key"
STORAGE_BOX="${STORAGE_BOX_USER}@${STORAGE_BOX_HOST}"

mkdir -p "$BACKUP_DIR"

docker exec health_postgres \
    pg_dump -U "$POSTGRES_USER" "$POSTGRES_DB" \
    | gzip > "$BACKUP_DIR/$BACKUP_FILE"

rsync -e "ssh $SSH_OPTS" \
    "$BACKUP_DIR/$BACKUP_FILE" \
    "${STORAGE_BOX}:backups/"

find "$BACKUP_DIR" -name "*.sql.gz" -mtime +$RETENTION_DAYS -delete

echo "$(date -Iseconds) backup ok: $BACKUP_FILE"
